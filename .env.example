# Copy this file to .env and adjust as needed for local docker-compose runs.
# All values below are the defaults docker-compose.yml already falls back to,
# so an .env file is only required if you want to override them.
#   docker compose up

# Raft node identity and storage. A single node bootstraps its own
# single-member cluster; TOGGLY_RAFT_DATA_DIR must point at a persistent
# volume (see the toggly-raft-data volume in docker-compose.yml) for flag
# data to survive a container restart.
TOGGLY_RAFT_NODE_ID=node1
TOGGLY_RAFT_BIND_ADDR=:9100
TOGGLY_RAFT_DATA_DIR=./data
TOGGLY_RAFT_BOOTSTRAP=true

# Signing secret for issued JWTs. Falls back to an insecure development
# default if unset -- always set this in any real deployment.
TOGGLY_JWT_SECRET=toggly-dev-secret
